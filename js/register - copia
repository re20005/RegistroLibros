// VARIABLES GLOBALES

let registros = JSON.parse(localStorage.getItem("registros")) || [];

// FUNCIONES CRUD

// Crear
function crearRegistro(data) {
  try {
    if (!data.nombre || !data.correo || !data.password || !data.cpassword) {
      throw new Error("Todos los campos son obligatorios");
    }
    if (data.password !== data.cpassword) {
      throw new Error("Las contraseñas no coinciden");
    }

    // Obtener ubicación antes de guardar
    navigator.geolocation.getCurrentPosition(async (pos) => {
      const lat = pos.coords.latitude;
      const lon = pos.coords.longitude;

      try {
        const resp = await fetch(
          `https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${lat}&longitude=${lon}&localityLanguage=es`
        );
        const ubicacion = await resp.json();

        // Agregar ubicación al registro
        data.ubicacion = {
          ciudad: ubicacion.city,
          pais: ubicacion.countryName,
          lat,
          lon,
        };

        registros.push(data);
        localStorage.setItem("registros", JSON.stringify(registros));
        listarRegistros();
        actualizarDashboard();

        alert(`Registro creado en ${ubicacion.city}, ${ubicacion.countryName}`);
      } catch (error) {
        alert("Error al obtener ubicación: " + error.message);
      }
    });
  } catch (error) {
    alert("Error al crear registro: " + error.message);
  }
}

// Editar
function editarRegistro(index, nuevoData) {
  try {
    if (!registros[index]) throw new Error("Registro no encontrado");
    registros[index] = nuevoData;
    localStorage.setItem("registros", JSON.stringify(registros));
    listarRegistros();
    actualizarDashboard();
  } catch (error) {
    alert("Error al editar: " + error.message);
  }
}

// Eliminar
function eliminarRegistro(index) {
  try {
    if (!registros[index]) throw new Error("Registro no encontrado");
    registros.splice(index, 1);
    localStorage.setItem("registros", JSON.stringify(registros));
    listarRegistros();
    actualizarDashboard();
  } catch (error) {
    alert("Error al eliminar: " + error.message);
  }
}

// Listar
function listarRegistros() {
  const lista = document.getElementById("listaRegistros");
  lista.innerHTML = "";
  registros.forEach((reg, i) => {
    const item = document.createElement("li");
    item.textContent = `${reg.nombre} - ${reg.correo} (${reg.ubicacion?.ciudad || "Sin ubicación"})`;
    item.innerHTML += `
      <button onclick="editarRegistro(${i}, {nombre:'Nuevo', correo:'nuevo@mail.com', password:'123', cpassword:'123'})">Editar</button>
      <button onclick="eliminarRegistro(${i})">Eliminar</button>
    `;
    lista.appendChild(item);
  });
}

// VALIDACIONES
document.getElementById("formRegistro").addEventListener("submit", function (e) {
  e.preventDefault();
  const nombre = document.getElementById("nombre").value.trim();
  const correo = document.getElementById("correo").value.trim();
  const password = document.getElementById("password").value.trim();
  const cpassword = document.getElementById("cpassword").value.trim();

  if (!nombre || !correo || !password || !cpassword) {
    alert("Todos los campos son obligatorios");
    return;
  }

  if (password !== cpassword) {
    alert("Las contraseñas no coinciden");
    return;
  }

  crearRegistro({ nombre, correo, password, cpassword });
  e.target.reset();
});

// DASHBOARD
function actualizarDashboard() {
  document.getElementById("totalRegistros").textContent = registros.length;

  if (registros.length > 0) {
    const ultimaUbicacion = registros[registros.length - 1].ubicacion;
    if (ultimaUbicacion) {
      document.getElementById("ubicacion").textContent =
        `Última ubicación registrada: ${ultimaUbicacion.ciudad}, ${ultimaUbicacion.pais}`;
    }
  }
}

// WEB WORKER
if (window.Worker) {
  const worker = new Worker("worker.js");
  worker.postMessage(registros);

  worker.onmessage = function (e) {
    document.getElementById("metricas").textContent = e.data;
  };
}

// CONSUMO DE API REST
async function cargarUbicacion() {
  try {
    navigator.geolocation.getCurrentPosition(async (pos) => {
      const lat = pos.coords.latitude;
      const lon = pos.coords.longitude;

      const resp = await fetch(
        `https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${lat}&longitude=${lon}&localityLanguage=es`
      );
      const data = await resp.json();

      document.getElementById("ubicacion").textContent =
        `Ubicación actual: ${data.city}, ${data.countryName}`;
    });
  } catch (error) {
    console.error("Error en geolocalización/API:", error);
  }
}
cargarUbicacion();
